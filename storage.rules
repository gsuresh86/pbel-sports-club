rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // Tournament banners - public read; authenticated write (role gated in app / Admin SDK)
    match /tournament-banners/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // User profile images - users can manage their own
    match /user-profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Test uploads - authenticated users only
    match /test-uploads/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    // Player profile photos from public registration (size/type limited; App Check in later phase)
    match /participant-profiles/{tournamentId}/{fileName} {
      allow read: if true;
      allow create: if request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow update: if false;
      allow delete: if isSignedIn();
    }

    // Team logos uploaded by signed-in staff (role gated in app)
    match /team-logos/{tournamentId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Participant documents - authenticated users only
    match /participant-documents/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
