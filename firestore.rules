rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin - simplified to avoid circular dependencies
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super-admin'];
    }
    
    // Helper function to check if user is tournament admin
    function isTournamentAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super-admin', 'tournament-admin'];
    }

    function isReferee() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'referee';
    }

    function isStaff() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['staff', 'referee'];
    }

    function hasTournamentPermission(tournamentId, permission) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return 'tournamentPermissions' in userData
        && userData.tournamentPermissions is map
        && tournamentId in userData.tournamentPermissions
        && userData.tournamentPermissions[tournamentId] is list
        && userData.tournamentPermissions[tournamentId].hasAny([permission]);
    }

    function isAssignedToTournament(tournamentId) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return 'assignedTournaments' in userData
        && userData.assignedTournaments is list
        && userData.assignedTournaments.hasAny([tournamentId]);
    }

    function matchDocTournamentId() {
      return request.resource.data.tournamentId != null
        ? request.resource.data.tournamentId
        : resource.data.tournamentId;
    }

    function canManageTournamentMatches(tournamentId) {
      return isTournamentAdmin()
        || (isReferee() && isAssignedToTournament(tournamentId))
        || (isAssignedToTournament(tournamentId) && hasTournamentPermission(tournamentId, 'tournament.matches.write'));
    }

    // Matches UI gate isFullTournamentAdmin() — keep Firestore in sync:
    // system/tournament admins, or assigned staff with overview / tournament-admin role slug.
    function hasTournamentAdminRoleSlug(tournamentId) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return 'tournamentRoles' in userData
        && userData.tournamentRoles is map
        && tournamentId in userData.tournamentRoles
        && userData.tournamentRoles[tournamentId] is list
        && userData.tournamentRoles[tournamentId].hasAny(['tournament-admin']);
    }

    function canManageTournamentDocument(tournamentId) {
      return isTournamentAdmin()
        || (isAssignedToTournament(tournamentId)
            && hasTournamentPermission(tournamentId, 'tournament.overview'))
        || (isAssignedToTournament(tournamentId)
            && hasTournamentAdminRoleSlug(tournamentId));
    }

    // Staff accounts created via the permission system use role == 'staff'
    // (with tournamentRoles/tournamentPermissions). They still need the staff
    // directory for tournament user management.
    function isAssignedStaff() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userData.role == 'staff'
        && 'assignedTournaments' in userData
        && userData.assignedTournaments is list
        && userData.assignedTournaments.size() > 0;
    }

    function canAccessStaffDirectory() {
      return isAdmin() || isTournamentAdmin() || isAssignedStaff();
    }

    function isStaffDirectoryRole() {
      return resource.data.role in ['referee', 'tournament-admin', 'staff'];
    }

    // Privileged fields users must never change on their own document
    function userPrivilegeKeysChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'tournamentPermissions', 'tournamentRoles', 'assignedTournaments', 'isActive', 'createdBy']);
    }

    // User documents - allow authenticated users to read their own document
    match /users/{userId} {
      // List queries must constrain role to staff directory roles.
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin() ||
        (canAccessStaffDirectory() && isStaffDirectoryRole())
      );
      // Public signup may only create own doc as role "public"
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == 'public';
      allow update: if request.auth != null && (
        // Self-update: profile fields only — never privileges
        (request.auth.uid == userId && !userPrivilegeKeysChanged()) ||
        isAdmin() ||
        (canAccessStaffDirectory() &&
          resource.data.role in ['referee', 'staff', 'tournament-admin'] &&
          request.resource.data.role in ['referee', 'staff', 'tournament-admin'])
      );
      allow delete: if request.auth != null && (
        isAdmin() ||
        (canAccessStaffDirectory() && isStaffDirectoryRole())
      );
    }

    // Tournaments - public read, role-based write
    match /tournaments/{tournamentId} {
      allow read: if true; // Public read for tournament listings
      allow create: if request.auth != null && isTournamentAdmin();
      allow update: if request.auth != null && canManageTournamentDocument(tournamentId);
      allow delete: if request.auth != null && isAdmin();
    }

    function canReadTournamentPii(tournamentId) {
      return request.auth != null && (
        isAdmin()
        || isTournamentAdmin()
        || (isAssignedToTournament(tournamentId)
            && (hasTournamentPermission(tournamentId, 'tournament.participants')
                || hasTournamentPermission(tournamentId, 'tournament.players')
                || hasTournamentPermission(tournamentId, 'tournament.overview')
                || hasTournamentPermission(tournamentId, 'tournament.tshirt-distribution')
                || hasTournamentAdminRoleSlug(tournamentId)))
      );
    }

    function canWriteTournamentPii(tournamentId) {
      return request.auth != null && (
        isAdmin()
        || isTournamentAdmin()
        || (isAssignedToTournament(tournamentId)
            && (hasTournamentPermission(tournamentId, 'tournament.participants')
                || hasTournamentPermission(tournamentId, 'tournament.players')
                || hasTournamentAdminRoleSlug(tournamentId)
                || hasTournamentPermission(tournamentId, 'tournament.overview')))
      );
    }

    // Registrations - public create for signup; PII read/update restricted to staff
    match /registrations/{registrationId} {
      allow read: if false; // Legacy top-level; do not expose PII
      allow create: if false;
      allow update: if false;
      allow delete: if request.auth != null && isAdmin();
    }

    // Matches - public read; tournament-admin or assigned referee write
    match /tournaments/{tournamentId}/matches/{matchId} {
      allow read: if true;
      allow create, update: if request.auth != null && canManageTournamentMatches(tournamentId);
      allow delete: if request.auth != null && canManageTournamentMatches(tournamentId);
    }

    // Collection group queries on `matches` (e.g. find match by id without tournament in URL)
    match /{path=**}/matches/{matchId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
        && canManageTournamentMatches(matchDocTournamentId());
    }

    // Live Scores - public read; tournament-admin or assigned referee write
    match /tournaments/{tournamentId}/liveScores/{scoreId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && canManageTournamentMatches(tournamentId);
    }

    match /{path=**}/liveScores/{scoreId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
        && canManageTournamentMatches(matchDocTournamentId());
    }

    // Legacy top-level matches (read-only during migration)
    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;
    }

    // Legacy top-level live scores (read-only during migration)
    match /liveScores/{scoreId} {
      allow read: if true;
      allow write: if false;
    }

    // Winners - public read; assigned tournament managers write
    match /winners/{winnerId} {
      allow read: if true;
      allow create: if request.auth != null && canManageTournamentDocument(request.resource.data.tournamentId);
      allow update: if request.auth != null && canManageTournamentDocument(resource.data.tournamentId);
      allow delete: if request.auth != null && isAdmin();
    }

    // Registration Forms - public read; staff write
    match /registrationForms/{formId} {
      allow read: if true;
      allow create, update: if request.auth != null && isTournamentAdmin();
      allow delete: if request.auth != null && isTournamentAdmin();
    }

    // Tournament Brackets - public read; assigned managers write
    match /brackets/{bracketId} {
      allow read: if true;
      allow create: if request.auth != null && canManageTournamentDocument(request.resource.data.tournamentId);
      allow update: if request.auth != null && canManageTournamentDocument(resource.data.tournamentId);
      allow delete: if request.auth != null && isAdmin();
    }

    // Tournament Registrations — public may create; only staff may read/update/delete PII
    match /tournaments/{tournamentId}/registrations/{registrationId} {
      allow read: if canReadTournamentPii(tournamentId);
      allow create: if true;
      allow update: if canWriteTournamentPii(tournamentId);
      allow delete: if canWriteTournamentPii(tournamentId);
    }

    // Full player records — staff only after create-from-registration
    match /tournaments/{tournamentId}/players/{playerId} {
      allow read: if canReadTournamentPii(tournamentId);
      allow create: if true;
      allow update: if canWriteTournamentPii(tournamentId);
      allow delete: if canWriteTournamentPii(tournamentId);
    }

    // Public display projections (names/photos only) — readable by anyone
    match /tournaments/{tournamentId}/publicPlayers/{playerId} {
      allow read: if true;
      allow create, update: if
        request.resource.data.keys().hasOnly([
          'tournamentId', 'name', 'partnerName', 'profilePhotoUrl',
          'partnerProfilePhotoUrl', 'selectedCategory', 'updatedAt'
        ])
        && request.resource.data.tournamentId == tournamentId
        && request.resource.data.name is string
        && request.resource.data.selectedCategory is string
        && (
          canWriteTournamentPii(tournamentId)
          || (
            exists(/databases/$(database)/documents/tournaments/$(tournamentId)/registrations/$(playerId))
            && get(/databases/$(database)/documents/tournaments/$(tournamentId)/registrations/$(playerId)).data.name
              == request.resource.data.name
          )
        );
      allow delete: if canWriteTournamentPii(tournamentId);
    }

    // Tournament Teams Subcollection - admin/tournament-admin write
    match /tournaments/{tournamentId}/teams/{teamId} {
      allow read: if true; // Public read for tournament teams
      allow create, update, delete: if request.auth != null && canManageTournamentDocument(tournamentId);
    }

    // Tournament Pools Subcollection - admin/tournament-admin write
    match /tournaments/{tournamentId}/pools/{poolId} {
      allow read: if true; // Public read for tournament pools
      allow create, update, delete: if request.auth != null && canManageTournamentDocument(tournamentId);
    }

    // Tournament finances - sensitive: admin/tournament-admin only, NOT public
    match /tournaments/{tournamentId}/finances/{financeId} {
      allow read: if request.auth != null && canManageTournamentDocument(tournamentId);
      allow create: if request.auth != null && canManageTournamentDocument(tournamentId);
      allow update: if request.auth != null && canManageTournamentDocument(tournamentId);
      allow delete: if request.auth != null && canManageTournamentDocument(tournamentId);
    }

    // Tournament Leads - public create for lead capture, admin read/write
    match /tournamentLeads/{leadId} {
      allow read: if request.auth != null && isTournamentAdmin(); // Only admins can read leads
      allow create: if true; // Public create for lead capture from registration form
      allow update: if request.auth != null && isTournamentAdmin(); // Only admins can update
      allow delete: if request.auth != null && isTournamentAdmin(); // Only admins can delete
    }

    // App Settings - admin only
    match /appSettings/{settingsId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if request.auth != null && isAdmin();
      allow create: if request.auth != null && isAdmin();
      allow update: if request.auth != null && isAdmin();
      allow delete: if request.auth != null && isAdmin();
    }

    // Tournament roles - admins and assigned tournament staff manage custom roles
    match /roles/{roleId} {
      allow read: if request.auth != null && canAccessStaffDirectory();
      allow create: if request.auth != null && (
        isAdmin() ||
        (canAccessStaffDirectory() && request.resource.data.isSystem == false)
      );
      allow update: if request.auth != null && (
        isAdmin() ||
        (canAccessStaffDirectory() &&
          resource.data.isSystem == false &&
          request.resource.data.isSystem == false)
      );
      allow delete: if request.auth != null && (
        isAdmin() ||
        (canAccessStaffDirectory() && resource.data.isSystem == false)
      );
    }

    // Helper: super-admin only
    function isSuperAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin';
    }

    // Testimonials - public read; tournament-admin create/edit content; super-admin can publish
    match /testimonials/{testimonialId} {
      allow read: if true;
      // Tournament admins can create, but must set published: false
      allow create: if request.auth != null && isTournamentAdmin()
                    && request.resource.data.published == false;
      // Tournament admins can update content fields but NOT change published flag
      // Super-admins can update anything (including published)
      allow update: if request.auth != null && (
        isSuperAdmin() ||
        (isTournamentAdmin() && request.resource.data.published == resource.data.published)
      );
      allow delete: if request.auth != null && (
        isSuperAdmin() ||
        (isTournamentAdmin() && resource.data.published == false)
      );
    }

    // Notifications - users can read/update their own notifications
    match /notifications/{notificationId} {
      // Allow read if user is authenticated and owns the notification
      allow read: if request.auth != null && 
                     request.auth.uid != null &&
                     resource.data.userId == request.auth.uid;
      // Allow create for authenticated users (system creates notifications)
      allow create: if request.auth != null && request.auth.uid != null;
      // Allow update if user owns the notification (for marking as read)
      allow update: if request.auth != null && 
                       request.auth.uid != null &&
                       request.auth.uid == resource.data.userId;
      // Allow delete if user owns the notification
      allow delete: if request.auth != null && 
                       request.auth.uid != null &&
                       request.auth.uid == resource.data.userId;
    }
  }
}